# ======================================================
# Claw 错题管理系统 - .gitignore
# ======================================================

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
*.egg
dist/
build/
*.spec
eggs/
.eggs/
*.manifest
*.spec

# ── Virtual Environment ──
venv/
.env
.venv
env/
ENV/

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── PyInstaller 构建产物 ──
apps/desktop/dist/
apps/desktop/build/
apps/desktop/*.spec
apps/desktop/app_icon.ico

# ── 测试报告 ──
reports/
htmlcov/
.coverage
.coverage.*
*.cover
.pytest_cache/

# ── 日志文件 ──
logs/*.log
apps/web/api/logs/*.log
apps/desktop/local_cache/

# ── 上传/输出目录（运行时生成） ──
data/uploads/*
data/output/*
data/logs/*
!data/uploads/.gitkeep
!data/output/.gitkeep
!data/logs/.gitkeep
apps/web/api/uploads/*
apps/web/api/output/*
!apps/web/api/uploads/.gitkeep
!apps/web/api/output/.gitkeep
uploads/*
!uploads/.gitkeep

# ── NAS 配置（含密码） ──
apps/desktop/nas_config.json

# ── 环境配置（含密钥） ──
apps/web/api/.env
*.env.local
*.env.production

# ── 临时文件 ──
*.tmp
*.temp
*.bak
*.cache
tmp/
temp/
~$*

# ── 操作系统 ──
Desktop.ini
$RECYCLE.BIN/

# ── 测试输出文件 ──
markdown_test_result.txt
test_output.txt
*_result.txt

# ── 其他 ──
*.wpr
*.wpu
